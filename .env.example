# Firebase (client-side - NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only API keys (never expose to client)
GEMINI_API_KEY=
SEARCHAPI_API_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_PRODUCT_ID=

# Base URL used to build Stripe success/cancel redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin SDK service account (server-only).
# Paste the full service-account JSON on a single line wrapped in single quotes.
FIREBASE_SERVICE_ACCOUNT_KEY=
